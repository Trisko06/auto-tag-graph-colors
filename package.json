{
  "name": "auto-tag-graph-colors",
  "version": "1.0.0",
  "description": "Obsidian plugin — automatically assigns distinct, stable colors to every tag in the Graph View.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": ["obsidian", "obsidian-plugin", "graph", "tags", "colors", "visualization"],
  "author": "Meetzy Corp FZCO <hello@meetzy.ai> (https://meetzy.ai)",
  "license": "MIT",
  "homepage": "https://meetzy.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/Trisko06/auto-tag-graph-colors.git"
  },
  "bugs": {
    "url": "https://github.com/Trisko06/auto-tag-graph-colors/issues"
  },
  "devDependencies": {
    "@types/node": "^16.11.6",
    "builtin-modules": "3.3.0",
    "esbuild": "0.17.3",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.7.4"
  }
}
