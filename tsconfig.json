{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2018",
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "strict": true,
    "strictNullChecks": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["ES2018", "DOM"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
